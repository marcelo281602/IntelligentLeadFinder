# ─────────────────────────────────────────────────────────────────────────────
# LeadFinder environment template.
# Copy to .env.local (web) / .env (worker) and fill in real values.
# NEVER commit real values. All placeholders below are safe.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (hosted project or self-hosted stack) ──────────────────────────
# Public values — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only. The service-role key bypasses RLS — web server and worker only.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Direct Postgres connection for the worker (Supabase → Settings → Database).
# Use the pooled connection string in production.
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# ── Application secrets (server-only) ────────────────────────────────────────
# Master key for envelope encryption of provider credentials.
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=GENERATE-A-32-BYTE-BASE64-KEY

# HMAC secret for signed download URLs and provider callback tokens.
# Generate with: openssl rand -base64 32
APP_SIGNING_SECRET=GENERATE-A-32-BYTE-BASE64-SECRET

# ── Application config ────────────────────────────────────────────────────────
# local | test | staging | production
APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Provider mode: "fixture" runs the full pipeline on deterministic test data
# with no paid calls; "live" calls the real provider APIs with BYO keys.
PROVIDER_MODE=fixture

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_MS=2000
WORKER_CONCURRENCY=2

# Local directory for generated export files in development.
# Production should use private object storage (e.g. Supabase Storage).
EXPORT_STORAGE_DIR=.local-storage/exports

# ── Google Sheets OAuth (optional) ───────────────────────────────────────────
# Enables the "Sign in with Google" Sheets destination (drive.file scope).
# Leave unset to offer only the Apps Script / webhook path.
# Create at: Google Cloud Console → APIs & Services → Credentials →
#   OAuth 2.0 Client ID (Web application). Authorized redirect URI must be
#   <NEXT_PUBLIC_APP_URL>/api/oauth/google/callback  (see docs/GOOGLE_SHEETS_OAUTH.md).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
