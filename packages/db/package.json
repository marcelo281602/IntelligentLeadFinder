  },
  "dependencies": {
    "@leadfinder/core": "*",
    "@leadfinder/security": "*",
    "@supabase/supabase-js": "2.110.6",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "3.2.7"
  }
